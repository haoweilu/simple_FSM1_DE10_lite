(header "symbol" (version "1.1"))
(symbol
	(rect 16 16 192 128)
	(text "FSM1" (rect 5 0 28 12)(font "Arial" ))
	(text "inst" (rect 8 96 20 108)(font "Arial" ))
	(port
		(pt 0 32)
		(input)
		(text "clk" (rect 0 0 10 12)(font "Arial" ))
		(text "clk" (rect 21 27 31 39)(font "Arial" ))
		(line (pt 0 32)(pt 16 32)(line_width 1))
	)
	(port
		(pt 0 48)
		(input)
		(text "rst_n" (rect 0 0 21 12)(font "Arial" ))
		(text "rst_n" (rect 21 43 42 55)(font "Arial" ))
		(line (pt 0 48)(pt 16 48)(line_width 1))
	)
	(port
		(pt 0 64)
		(input)
		(text "in" (rect 0 0 5 12)(font "Arial" ))
		(text "in" (rect 21 59 26 71)(font "Arial" ))
		(line (pt 0 64)(pt 16 64)(line_width 1))
	)
	(port
		(pt 176 32)
		(output)
		(text "out_data[3..0]" (rect 0 0 54 12)(font "Arial" ))
		(text "out_data[3..0]" (rect 101 27 155 39)(font "Arial" ))
		(line (pt 176 32)(pt 160 32)(line_width 3))
	)
	(parameter
		"s0"
		"0"
		""
		(type "PARAMETER_SIGNED_DEC")	)
	(parameter
		"s1"
		"1"
		""
		(type "PARAMETER_SIGNED_DEC")	)
	(parameter
		"s2"
		"2"
		""
		(type "PARAMETER_SIGNED_DEC")	)
	(parameter
		"s3"
		"3"
		""
		(type "PARAMETER_SIGNED_DEC")	)
	(drawing
		(rectangle (rect 16 16 160 96)(line_width 1))
	)
	(annotation_block (parameter)(rect 192 -64 292 16))
)
